/* Question : what are the top paying data analyst jobs?
identify top 10 most paying jobs as data analyst remotly 
also focus on job postings with specifeid salaries (avoid null)
 */

 select job_id,
 job_title,
 job_location,
 b.name as company_name,
 job_schedule_type,
 salary_year_avg,
 job_posted_date
 FROM job_postings_fact as a
 left JOIN company_dim as b ON a.company_id=b.company_id
 where job_title_short='Data Analyst' and job_location='Anywhere'
 and salary_year_avg is NOT NULL
 ORDER BY 
 salary_year_avg DESC
 LIMIT 10