/*Question : what are the top skills based on salary ?
we will be averaging the salary for each skills and then comparing the top salaries
Why ? it helps you identify the most rewarding skills to aquire asa data analyst*/

select skills_dim.skill_id,
skills,
 round(avg(salary_year_avg),0) salary_avg
FROM job_postings_fact
INNER JOIN skills_job_dim ON skills_job_dim.job_id=job_postings_fact.job_id
INNER JOIN skills_dim ON skills_job_dim.skill_id=skills_dim.skill_id
where job_title_short='Data Analyst' 
and salary_year_avg IS NOT NULL
--AND job_work_from_home=true
GROUP BY
skills,skills_dim.skill_id
ORDER BY salary_avg DESC
LIMIT 100

